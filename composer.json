{
	"name": "hypejunction/hypeajax",
	"type": "elgg-plugin",
	"description": "Ajax utilities",
	"homepage": "https://github.com/hypeJunction/Elgg3-hypeAjax",
	"keywords": [
		"elgg",
		"plugin",
		"ajax"
	],
	"license": "GPL-2.0-or-later",
	"require": {
		"composer/installers": "^2.0",
		"php": ">=8.1",
		"elgg/elgg": "~6.1.0"
	},
	"autoload": {
		"psr-4": {
			"hypeJunction\\Ajax\\": "classes/hypeJunction/Ajax/"
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	},
	"extra": {
		"elgg-plugin": {
			"id": "hypeajax"
		}
	}
}
